    s223:connectsAt wbs:conn-Primary_Sedimentation-to-Primary_Sedimentation_Junction ;
    s223:connectsThrough wbs:conn-Primary_Sedimentation-to-Primary_Sedimentation_Junction ;
    s223:hasMedium s223:Medium-Water .

wbs:Primary_Sedimentation_Junction-inlet-cp-2 a s223:InletConnectionPoint ;
    s223:connectsAt wbs:conn-Flow_Return_Pump1-to-Primary_Sedimentation_Junction ;
    s223:connectsThrough wbs:conn-Flow_Return_Pump1-to-Primary_Sedimentation_Junction ;
    s223:hasMedium s223:Medium-Water .

