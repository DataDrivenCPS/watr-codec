@prefix nawi: <urn:nawi-water-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix s223: <http://data.ashrae.org/standard223#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix wbs: <urn:ex/> .

wbs: a owl:Ontology .

wbs:AS_Aeration_Basin-mlss-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Sludge-MixedLiquor ;
    s223:ofSubstance s223:Solids-SuspendedSolids ;
    qudt:hasQuantityKind qudtqk:Density ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:AS_Aeration_Basin-volume a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Volume ;
    qudt:hasUnit unit:GAL_US .

wbs:AS_Secondary_Sedimentation-volume a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Volume ;
    qudt:hasUnit unit:GAL_US .

wbs:Chlorination_Basin-cl2-mgL a s223:QuantifiableObservableProperty ;
    s223:ofSubstance nawi:Chlorine ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Chlorination_Basin-volume a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Volume ;
    qudt:hasUnit unit:GAL_US .

wbs:Effluent_Pump-out-bacteria-enterococcus a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Bacteria ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:CFU-PER-100ML .

wbs:Effluent_Pump-out-biochemical-oxygen-demand a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Oxygen ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Effluent_Pump-out-cl2-mgL a s223:QuantifiableObservableProperty ;
    s223:ofSubstance nawi:Chlorine ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Effluent_Pump-out-copper a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Metals ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MicroGM-PER-L .

wbs:Effluent_Pump-out-cyanide a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Cyanide ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MicroGM-PER-L .

wbs:Effluent_Pump-out-flow-rate a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate .

wbs:Effluent_Pump-out-nh4-mgL a s223:QuantifiableObservableProperty ;
    s223:ofSubstance nawi:Ammonia ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Effluent_Pump-out-ph a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Acidity ;
    qudt:hasUnit unit:PH .

wbs:Effluent_Pump-out-teq-dioxin a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Organics ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MicroGM-PER-L .

wbs:Effluent_Pump-out-tss-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance s223:Solids-SuspendedSolids ;
    qudt:hasQuantityKind qudtqk:Density ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Effluent_Pump-speed-command a s223:QuantifiableActuatableProperty ;
    qudt:hasQuantityKind qudtqk:SpeedRatio ;
    qudt:hasUnit unit:PERCENT .

wbs:Grinder-electric-current a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:ElectricCurrent ;
    qudt:hasUnit unit:A .

wbs:Influent_Pump a nawi:Pump ;
    s223:cnx wbs:Influent_Pump-out ;
    s223:connected wbs:Screen ;
    s223:connectedThrough wbs:conn-Influent_Pump-to-Screen ;
    s223:connectedTo wbs:Screen ;
    s223:hasConnectionPoint wbs:Influent_Pump-in,
        wbs:Influent_Pump-out ;
    s223:hasProperty wbs:Influent_Pump-status .

wbs:Influent_Pump-in a s223:InletConnectionPoint ;
    s223:hasMedium s223:Medium-Water ;
    s223:hasProperty wbs:Influent_Pump-in-biochemical-oxygen-demand,
        wbs:Influent_Pump-in-cyanide,
        wbs:Influent_Pump-in-flow-rate,
        wbs:Influent_Pump-in-tss-concentration .

wbs:Influent_Pump-in-biochemical-oxygen-demand a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Oxygen ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Influent_Pump-in-cyanide a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Cyanide ;
    qudt:hasQuantityKind qudtqk:Concentration ;
    qudt:hasUnit unit:MicroGM-PER-L .

wbs:Influent_Pump-in-flow-rate a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate .

wbs:Influent_Pump-in-tss-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance s223:Solids-SuspendedSolids ;
    qudt:hasQuantityKind qudtqk:Density ;
    qudt:hasUnit unit:MilliGM-PER-L .

wbs:Influent_Pump-status a s223:QuantifiableObservableProperty ;
    qudt:hasEnumerationKind s223:EnumerationKind-Status .

wbs:Primary_Sedimentation-turbidity a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Turbidity ;
    qudt:hasUnit unit:NTU .

wbs:Primary_Sedimentation-volume a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Volume ;
    qudt:hasUnit unit:GAL_US .

wbs:RBC_Secondary_Sedimentation-volume a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Volume ;
    qudt:hasUnit unit:GAL_US .

wbs:Sluice_Gate-opening-command a s223:QuantifiableActuatableProperty ;
    qudt:hasQuantityKind qudtqk:OpeningRatio .

wbs:Sluice_Gate-status a s223:QuantifiableObservableProperty ;
    qudt:hasEnumerationKind s223:EnumerationKind-Status .

wbs:Storage_Basin-volume a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Volume ;
    qudt:hasUnit unit:GAL_US .

wbs:Wet_Weather_Screen a nawi:Screen ;
    s223:cnx wbs:Wet_Weather_Screen-in,
        wbs:Wet_Weather_Screen-out ;
    s223:connected wbs:Storage_Basin ;
    s223:connectedThrough wbs:conn-Wet_Weather_Screen-to-Storage_Basin ;
    s223:connectedTo wbs:Storage_Basin ;
    s223:hasConnectionPoint wbs:Wet_Weather_Screen-in,
        wbs:Wet_Weather_Screen-out ;
    s223:hasProcess nawi:Process-Screening .

wbs:Dewatering_Unit-out a s223:OutletConnectionPoint ;
    s223:hasMedium nawi:Fluid-Sludge .

wbs:Wet_Weather_Screen-in a s223:InletConnectionPoint ;
    s223:hasMedium s223:Medium-Water .

wbs:AS_Aeration_Basin-in a s223:InletConnectionPoint ;
    s223:connectsAt wbs:conn-Primary_Sedimentation_Junction-to-AS_Aeration_Basin ;
    s223:connectsThrough wbs:conn-Primary_Sedimentation_Junction-to-AS_Aeration_Basin ;
    s223:hasMedium s223:Medium-Water .

wbs:AS_Aeration_Basin-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-AS_Aeration_Basin-to-AS_Secondary_Sedimentation ;
    s223:connectsAt wbs:conn-AS_Aeration_Basin-to-AS_Secondary_Sedimentation ;
    s223:connectsThrough wbs:conn-AS_Aeration_Basin-to-AS_Secondary_Sedimentation ;
    s223:hasMedium s223:Medium-Water .

wbs:AS_Secondary_Sedimentation-in a s223:InletConnectionPoint ;
    s223:connectsAt wbs:conn-AS_Aeration_Basin-to-AS_Secondary_Sedimentation ;
    s223:connectsThrough wbs:conn-AS_Aeration_Basin-to-AS_Secondary_Sedimentation ;
    s223:hasMedium s223:Medium-Water .

wbs:AS_Secondary_Sedimentation-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-AS_Secondary_Sedimentation-to-Chlorination_Chamber ;
    s223:connectsAt wbs:conn-AS_Secondary_Sedimentation-to-Chlorination_Chamber ;
    s223:connectsThrough wbs:conn-AS_Secondary_Sedimentation-to-Chlorination_Chamber ;
    s223:hasMedium s223:Medium-Water .

wbs:Chlorination_Basin-in a s223:InletConnectionPoint ;
    s223:connectsAt wbs:conn-Chlorination_Chamber-to-Chlorination_Basin ;
    s223:connectsThrough wbs:conn-Chlorination_Chamber-to-Chlorination_Basin ;
    s223:hasMedium s223:Medium-Water .

wbs:Chlorination_Basin-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-Chlorination_Basin-to-Effluent_Pump ;
    s223:connectsAt wbs:conn-Chlorination_Basin-to-Effluent_Pump ;
    s223:connectsThrough wbs:conn-Chlorination_Basin-to-Effluent_Pump ;
    s223:hasMedium s223:Medium-Water .

wbs:Chlorination_Chamber-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-Chlorination_Chamber-to-Chlorination_Basin ;
    s223:connectsAt wbs:conn-Chlorination_Chamber-to-Chlorination_Basin ;
    s223:connectsThrough wbs:conn-Chlorination_Chamber-to-Chlorination_Basin ;
    s223:hasMedium s223:Medium-Water .

wbs:Dewatering_Unit a nawi:DewateringUnit ;
    s223:cnx wbs:Dewatering_Unit-in,
        wbs:Dewatering_Unit-out ;
    s223:connectedThrough wbs:conn-Sludge_Digester-to-Dewatering_Unit ;
    s223:hasConnectionPoint wbs:Dewatering_Unit-in,
        wbs:Dewatering_Unit-out ;
    nawi:hasProcess nawi:Process-Dewatering .

wbs:Dewatering_Unit-in a s223:InletConnectionPoint ;
    s223:connectsAt wbs:conn-Sludge_Digester-to-Dewatering_Unit ;
    s223:connectsThrough wbs:conn-Sludge_Digester-to-Dewatering_Unit ;
    s223:hasMedium nawi:Fluid-Sludge .

wbs:Effluent_Pump-in a s223:InletConnectionPoint ;
    s223:connectsAt wbs:conn-Chlorination_Basin-to-Effluent_Pump ;
    s223:connectsThrough wbs:conn-Chlorination_Basin-to-Effluent_Pump ;
    s223:hasMedium s223:Medium-Water .

wbs:Effluent_Pump-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-Effluent_Pump-to-Storage_Basin ;
    s223:connectsAt wbs:conn-Effluent_Pump-to-Storage_Basin ;
    s223:connectsThrough wbs:conn-Effluent_Pump-to-Storage_Basin ;
    s223:hasMedium s223:Medium-Water ;
    s223:hasProperty wbs:Effluent_Pump-out-bacteria-enterococcus,
        wbs:Effluent_Pump-out-biochemical-oxygen-demand,
        wbs:Effluent_Pump-out-cl2-mgL,
        wbs:Effluent_Pump-out-copper,
        wbs:Effluent_Pump-out-cyanide,
        wbs:Effluent_Pump-out-flow-rate,
        wbs:Effluent_Pump-out-nh4-mgL,
        wbs:Effluent_Pump-out-ph,
        wbs:Effluent_Pump-out-teq-dioxin,
        wbs:Effluent_Pump-out-tss-concentration .

