    s223:connectsAt wbs:conn-Diurnal_Flow_Box-to-Flow_Return_Pump1 ;
    s223:connectsThrough wbs:conn-Diurnal_Flow_Box-to-Flow_Return_Pump1 ;
    s223:hasMedium s223:Medium-Water .

